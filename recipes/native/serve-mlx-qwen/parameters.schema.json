{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model": {
      "type": "string",
      "description": "Cluster-scoped IdleloomModel catalog entry.",
      "default": "qwen3-5-0-8b-mlx",
      "format": "dnsSubdomain"
    },
    "modelAlias": {
      "type": "string",
      "description": "Stable model name accepted by the OpenAI-compatible API.",
      "default": "qwen3-5-0-8b",
      "format": "dnsSubdomain"
    },
    "namespace": {
      "type": "string",
      "description": "Namespace for the IdleloomWorkload, Service, and generated client Secret.",
      "default": "default",
      "format": "namespace"
    },
    "servicePort": {
      "type": "integer",
      "description": "ClusterIP Service port.",
      "default": 8000,
      "minimum": 1,
      "maximum": 65535
    },
    "unifiedMemory": {
      "type": "string",
      "description": "Unified memory reservation for model loading and serving.",
      "default": "8Gi",
      "format": "positiveQuantity"
    }
  }
}
