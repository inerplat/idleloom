FROM golang:1.25-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags='-s -w' -o /out/idleloom-projection ./cmd/idlectl

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /out/idleloom-projection /usr/local/bin/idleloom-projection
ENTRYPOINT ["/usr/local/bin/idleloom-projection", "--in-cluster", "--enable-kubernetes-projection"]
